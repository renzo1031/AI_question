/**app.wxss**/
/* 全局样式定义 */
page {
  /* Pro Max Design System - 极淡天空蓝主题 */
  --color-primary: #F0F9FF;      /* 极淡天空蓝 */
  --color-primary-light: #E0F2FE; /* 淡天空蓝 */
  --color-primary-dark: #BAE6FD;  /* 中淡天空蓝 */
  --color-secondary: #F8FAFC;     /* 极淡灰蓝 */
  --color-accent: #DBEAFE;        /* 天空蓝强调色 */
  --color-warning: #FEF3C7;
  --color-danger: #FEF2F2;
  --color-bg: #FFFFFF;             /* 纯白背景 */
  --color-surface: #FFFFFF;        /* 纯白表面 */
  --color-text-main: #1E293B;     /* 更深的蓝灰色文字 */
  --color-text-sub: #475569;       /* 次要文字调整为中等深度 */
  --color-text-light: #64748B;     /* 浅色文字保持 */
  --shadow-sm: 0 2rpx 4rpx 0 rgba(15, 23, 42, 0.03);
  --shadow-md: 0 8rpx 12rpx -2rpx rgba(15, 23, 42, 0.06), 0 4rpx 8rpx -2rpx rgba(15, 23, 42, 0.03);
  --shadow-lg: 0 20rpx 30rpx -6rpx rgba(15, 23, 42, 0.08), 0 8rpx 12rpx -4rpx rgba(15, 23, 42, 0.04);

  --td-font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  --td-brand-color: var(--color-primary);
  --td-brand-color-light: var(--color-primary-light);
  --td-success-color: var(--color-accent);
  --td-warning-color: var(--color-warning);
  --td-error-color: var(--color-danger);
  --td-text-color-primary: var(--color-text-main);
  --td-text-color-secondary: var(--color-text-sub);
  --td-text-color-placeholder: var(--color-text-light);
  --td-text-color-disabled: rgba(148, 163, 184, 0.5);
  --td-bg-color-page: var(--color-bg);
  --td-bg-color-container: var(--color-surface);
  --td-bg-color-component: #F0F9FF;    /* 极淡蓝组件背景 */
  --td-border-color: #E0F2FE;       /* 淡蓝边框 */
  --td-shadow-1: var(--shadow-sm);
  --td-shadow-2: var(--shadow-md);
  
  background-color: var(--color-bg);
  color: var(--color-text-main);
  font-family: var(--td-font-family);
  font-size: 28rpx;
  line-height: 1.5;
}

/* 通用容器样式 */
.container {
  box-sizing: border-box;
}

.page-container {
  min-height: 100vh;
  background-color: var(--td-bg-color-page);
  padding-bottom: 100rpx; /* 为底部导航留出空间 */
}

/* 卡片样式 */
.card {
  background-color: var(--td-bg-color-container);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--td-shadow-1);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
  margin-bottom: 16rpx;
}

.card-content {
  color: var(--td-text-color-secondary);
  font-size: 28rpx;
}

/* 列表样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid var(--td-border-color);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-icon {
  margin-right: 24rpx;
  color: var(--td-brand-color);
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  font-size: 30rpx;
  color: var(--td-text-color-primary);
  margin-bottom: 8rpx;
}

.list-item-desc {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
}

.list-item-arrow {
  color: var(--td-text-color-placeholder);
}

/* 按钮样式 */
.btn-primary {
  background-color: var(--td-brand-color);
  color: #ffffff;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  font-size: 30rpx;
  border: none;
}

.btn-secondary {
  background-color: transparent;
  color: var(--td-brand-color);
  border: 1px solid var(--td-brand-color);
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  font-size: 30rpx;
}

/* 表单样式 */
.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 30rpx;
  color: var(--td-text-color-primary);
  margin-bottom: 16rpx;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.tag-primary {
  background-color: rgba(248, 250, 252, 0.8);
  color: var(--color-text-main);
  border: 1px solid var(--color-primary-dark);
}

.tag-success {
  background-color: rgba(237, 243, 245, 0.8);
  color: var(--color-text-main);
  border: 1px solid var(--color-accent);
}

.tag-warning {
  background-color: rgba(254, 243, 199, 0.8);
  color: var(--color-text-main);
  border: 1px solid var(--color-warning);
}

.tag-error {
  background-color: rgba(254, 242, 242, 0.8);
  color: var(--color-text-main);
  border: 1px solid var(--color-danger);
}

/* 统计数据样式 */
.stats-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.stats-item {
  width: 48%;
  margin-bottom: 24rpx;
  text-align: center;
}

.stats-value {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--td-brand-color);
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
}

/* 进度条样式 */
.progress-container {
  margin-bottom: 32rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.progress-title {
  font-size: 28rpx;
  color: var(--td-text-color-primary);
}

.progress-value {
  font-size: 28rpx;
  color: var(--td-brand-color);
  font-weight: 500;
}

/* 空状态样式 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--td-text-color-placeholder);
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
}

/* 加载状态样式 */
.loading-container {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

/* 分隔线 */
.divider {
  height: 1px;
  background-color: var(--td-border-color);
  margin: 32rpx 0;
}

/* 响应式布局 */
@media (max-width: 750rpx) {
  .stats-item {
    width: 100%;
  }
} 
