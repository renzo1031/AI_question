page {
  background-color: var(--color-bg);
}

.container {
  padding: 30rpx;
  padding-bottom: 60rpx;
}

.card {
  background: var(--color-surface);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-md);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tags {
  display: flex;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.tag.subject {
  background: #EEF2FF;
  color: var(--color-primary);
}

.tag.type {
  background: #E2E8F0;
  color: var(--color-text-sub);
}

.difficulty {
  font-size: 24rpx;
  color: var(--color-text-light);
}

.card-content {
  font-size: 32rpx;
  line-height: 1.6;
  color: var(--color-text-main);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.ai-title {
  color: var(--color-primary);
}

.ai-title .icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.ai-provider {
  font-size: 20rpx;
  font-weight: normal;
  color: var(--color-text-light);
  margin-left: auto;
  background: #F8FAFC;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
}

.answer-content {
  font-size: 34rpx;
  color: var(--color-danger);
  font-weight: 500;
  padding: 20rpx;
  background: #FEF2F2;
  border-radius: 12rpx;
}

.answer-content.empty {
  color: var(--color-text-light);
  background: #F8FAFC;
  font-style: italic;
}

.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  color: var(--color-text-light);
  font-size: 26rpx;
}

.loading-icon {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E2E8F0;
  border-top: 4rpx solid var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.ai-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--color-text-main);
}

.sub-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-sub);
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--color-primary);
}

.ai-answer-section {
  margin-bottom: 32rpx;
}

.answer-box {
  background: #EEF2FF;
  padding: 24rpx;
  border-radius: 12rpx;
  color: #2c3e50;
  font-weight: 600;
  font-size: 32rpx;
}

.ai-analysis-section {
  margin-bottom: 32rpx;
}

.analysis-box {
  background: #F8FAFC;
  padding: 24rpx;
  border-radius: 12rpx;
  border: 1rpx solid #E2E8F0;
  color: var(--color-text-sub);
}

.options-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 20rpx;
  background: #F8FAFC;
  border-radius: 8rpx;
}

.option-label {
  font-weight: bold;
  color: var(--color-primary);
  margin-right: 12rpx;
}

.option-text {
  color: var(--color-text-sub);
}

.error-wrapper {
  text-align: center;
  padding: 40rpx 0;
}

.error-msg {
  color: var(--color-danger);
  font-size: 26rpx;
  display: block;
  margin-bottom: 24rpx;
}

.retry-btn {
  width: 240rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
  background: #fff;
  border-radius: 36rpx;
}
