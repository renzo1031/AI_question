page {
  background-color: var(--color-bg);
  /* 错题本页面专用配色 - 极淡天空蓝主题 */
  --mistake-primary: #0EA5E9;
  --mistake-primary-light: #38BDF8;
  --mistake-primary-dark: #0284C7;
  --mistake-text-primary: #1E293B;
  --mistake-text-secondary: #475569;
  --mistake-text-light: #64748B;
  --mistake-bg-card: #FFFFFF;
  --mistake-bg-section: #F0F9FF;
  --mistake-border: #E0F2FE;
  --mistake-shadow: var(--shadow-md);
  --mistake-danger: #EF4444;
  --mistake-warning: #F59E0B;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 顶部背景 - 天空蓝渐变 */
.header-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 600rpx;
  background: linear-gradient(180deg, #F0F9FF 0%, #E0F2FE 50%, var(--color-bg) 100%);
  z-index: -1;
}

/* 自定义导航栏 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 100;
  transition: all 0.3s ease;
}

.custom-nav.scrolled {
  background: rgba(240, 249, 255, 0.85);
  backdrop-filter: blur(12px);
  box-shadow: 0 1rpx 0 rgba(14, 165, 233, 0.1);
  -webkit-mask-image: linear-gradient(to bottom, black 85%, transparent 100%);
  mask-image: linear-gradient(to bottom, black 85%, transparent 100%);
}

.nav-content {
  padding-left: 32rpx;
  text-align: left;
  position: relative;
}

.nav-title {
  color: var(--mistake-text-primary);
  font-size: 36rpx;
  font-weight: 600;
}

/* 年级选择 - 现代化设计 */
.grade-section {
  padding: 20rpx 0 10rpx;
  position: relative;
  z-index: 95;
}

.grade-scroll {
  white-space: nowrap;
  padding: 0 30rpx;
  width: 100%;
  box-sizing: border-box;
  -webkit-mask-image: linear-gradient(to right, transparent 0%, #000 5%, #000 95%, transparent 100%);
  mask-image: linear-gradient(to right, transparent 0%, #000 5%, #000 95%, transparent 100%);
}

.grade-list {
  display: flex;
  padding-right: 40rpx;
}

.grade-item {
  padding: 12rpx 32rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: var(--mistake-text-secondary);
  background: rgba(255, 255, 255, 0.8);
  border-radius: 32rpx;
  transition: all 0.3s ease;
  flex-shrink: 0;
  border: 1px solid var(--mistake-border);
  font-weight: 500;
}

.grade-item.active {
  background: var(--mistake-primary);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(14, 165, 233, 0.3);
  border-color: var(--mistake-primary);
  transform: translateY(-2rpx);
}

/* 筛选区域 - 现代化卡片设计 */
.filter-container {
  padding: 10rpx 30rpx 20rpx;
  position: relative;
  z-index: 90;
  transition: all 0.3s ease;
}

.search-box {
  background: var(--mistake-bg-card);
  border-radius: 36rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--mistake-shadow);
  border: 1px solid var(--mistake-border);
  transition: all 0.3s ease;
}

.search-box:focus-within {
  border-color: var(--mistake-primary);
  box-shadow: 0 0 0 4rpx rgba(14, 165, 233, 0.1);
}

.search-box input {
  flex: 1;
  font-size: 28rpx;
  color: var(--mistake-text-primary);
  margin-left: 16rpx;
}

.search-box input::placeholder {
  color: var(--mistake-text-light);
}

/* 学科选择 */
.subject-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.subject-list {
  display: flex;
  padding: 4rpx 0;
}

.subject-item {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  margin-right: 16rpx;
  background: var(--mistake-bg-card);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: var(--mistake-text-secondary);
  box-shadow: var(--mistake-shadow);
  transition: all 0.3s ease;
  flex-shrink: 0;
  border: 1px solid var(--mistake-border);
  font-weight: 500;
}

.subject-item.active {
  background: var(--mistake-bg-section);
  color: var(--mistake-primary);
  border-color: var(--mistake-primary);
  font-weight: 600;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(14, 165, 233, 0.15);
}

.sub-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

/* 筛选行 */
.filter-row {
  display: flex;
  gap: 20rpx;
}

.flex-1 { flex: 1; }

.filter-btn {
  height: 64rpx;
  background: var(--mistake-bg-card);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  font-size: 24rpx;
  color: var(--mistake-text-secondary);
  box-shadow: var(--mistake-shadow);
  transition: all 0.3s ease;
  border: 1px solid var(--mistake-border);
  font-weight: 500;
}

.filter-btn.active {
  color: var(--mistake-primary);
  background: var(--mistake-bg-section);
  border-color: var(--mistake-primary);
  font-weight: 600;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(14, 165, 233, 0.15);
}

.truncate {
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arrow-down {
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-top: 6rpx solid var(--mistake-text-light);
  margin-left: 10rpx;
  transition: all 0.3s ease;
}

.filter-btn.active .arrow-down {
  border-top-color: var(--mistake-primary);
  transform: rotate(180deg);
}

/* 智能分析卡片 - 现代化设计 */
.analysis-card {
  background: linear-gradient(135deg, var(--mistake-bg-section) 0%, var(--mistake-bg-card) 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 28rpx;
  box-shadow: var(--mistake-shadow);
  border: 1px solid var(--mistake-border);
  position: relative;
  overflow: hidden;
}

.analysis-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--mistake-primary), var(--mistake-primary-light));
}

.analysis-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.analysis-badge {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, var(--mistake-primary), var(--mistake-primary-light));
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(14, 165, 233, 0.2);
}

.ai-icon {
  font-size: 20rpx;
  margin-right: 6rpx;
}

.ai-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
}

.analysis-time {
  font-size: 22rpx;
  color: var(--mistake-text-light);
  font-weight: 500;
}

.analysis-content {
  position: relative;
  z-index: 1;
}

.analysis-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.analysis-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  padding: 20rpx 16rpx;
  background: var(--mistake-bg-card);
  border-radius: 16rpx;
  border: 1px solid var(--mistake-border);
  margin: 0 8rpx;
  transition: all 0.3s ease;
}

.analysis-item:first-child {
  margin-left: 0;
}

.analysis-item:last-child {
  margin-right: 0;
}

.analysis-item:active {
  transform: scale(0.98);
  background: var(--mistake-bg-section);
}

.analysis-icon {
  font-size: 32rpx;
  margin-bottom: 12rpx;
}

.analysis-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.analysis-value {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--mistake-primary);
  margin-bottom: 4rpx;
}

.analysis-label {
  font-size: 20rpx;
  color: var(--mistake-text-secondary);
  font-weight: 500;
}

.analysis-suggestion {
  background: rgba(14, 165, 233, 0.05);
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1px solid rgba(14, 165, 233, 0.1);
}

.suggestion-text {
  font-size: 24rpx;
  color: var(--mistake-text-secondary);
  line-height: 1.6;
  font-weight: 500;
}
.stats-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 10rpx 24rpx;
  background: linear-gradient(135deg, var(--mistake-bg-section) 0%, var(--mistake-bg-card) 100%);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  border: 1px solid var(--mistake-border);
}

.stats-info {
  font-size: 26rpx;
  color: var(--mistake-text-secondary);
  font-weight: 500;
}

.stats-info .count {
  color: var(--mistake-primary);
  font-weight: bold;
  font-size: 32rpx;
  margin: 0 4rpx;
}

.stats-hint {
  font-size: 22rpx;
  color: var(--mistake-warning);
  background: rgba(245, 158, 11, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
  border: 1px solid rgba(245, 158, 11, 0.2);
}

/* 列表区域 */
.mistake-list {
  flex: 1;
  position: relative;
  z-index: 1;
  padding-bottom: 160rpx;
}

.content-wrapper {
  padding: 0 30rpx;
}

/* 错题卡片 - 现代化设计 */
.mistake-card {
  background: var(--mistake-bg-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 28rpx;
  box-shadow: var(--mistake-shadow);
  border: 1px solid var(--mistake-border);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.mistake-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
  background: linear-gradient(180deg, var(--mistake-danger) 0%, var(--mistake-warning) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.mistake-card:active::before {
  opacity: 1;
}

.mistake-card:active {
  transform: scale(0.98) translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.15);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-tags {
  display: flex;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  font-weight: 500;
}

.tag.subject {
  background: var(--mistake-bg-section);
  color: var(--mistake-primary);
  border: 1px solid var(--mistake-primary);
}

.tag.difficulty {
  background: var(--mistake-bg-section);
  color: var(--mistake-text-secondary);
  border: 1px solid var(--mistake-border);
}

.tag.type {
  background: rgba(245, 158, 11, 0.1);
  color: var(--mistake-warning);
  border: 1px solid rgba(245, 158, 11, 0.2);
}

.card-time {
  font-size: 22rpx;
  color: var(--mistake-text-light);
}

.card-body {
  font-size: 28rpx;
  color: var(--mistake-text-primary);
  line-height: 1.6;
  margin-bottom: 28rpx;
}

.last-answer {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(239, 68, 68, 0.05);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: var(--mistake-text-secondary);
  border-left: 6rpx solid var(--mistake-danger);
  border: 1px solid rgba(239, 68, 68, 0.1);
}

.ans-val {
  color: var(--mistake-danger);
  font-weight: 600;
  margin-left: 8rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1px solid var(--mistake-border);
}

.error-count {
  font-size: 24rpx;
  color: var(--mistake-text-secondary);
  display: flex;
  align-items: center;
  font-weight: 500;
}

.error-count .icon {
  margin-right: 6rpx;
}

.error-count .num {
  color: var(--mistake-danger);
  font-weight: 600;
  margin-left: 4rpx;
}

.detail-btn {
  font-size: 24rpx;
  color: var(--mistake-primary);
  font-weight: 600;
  display: flex;
  align-items: center;
  transition: all 0.3s ease;
}

.detail-btn:active {
  transform: scale(0.95);
}

.load-status {
  text-align: center;
  padding: 10rpx 0 0rpx;
  font-size: 24rpx;
  color: var(--mistake-text-light);
}

/* 空状态 - 现代化设计 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  background: linear-gradient(135deg, var(--mistake-bg-section) 0%, var(--mistake-bg-card) 100%);
  border-radius: 32rpx;
  margin-top: 40rpx;
  box-shadow: var(--mistake-shadow);
  border: 1px solid var(--mistake-border);
  position: relative;
  overflow: hidden;
}

.empty-state::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(14, 165, 233, 0.05) 0%, transparent 70%);
  animation: float 6s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-20px); }
}

.empty-img {
  width: 280rpx;
  height: 280rpx;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.empty-text {
  font-size: 28rpx;
  color: var(--mistake-text-secondary);
  margin-bottom: 48rpx;
  font-weight: 500;
  position: relative;
  z-index: 1;
}

.empty-btn {
  width: 320rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, var(--mistake-primary) 0%, var(--mistake-primary-dark) 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.3);
  position: relative;
  z-index: 1;
  transition: all 0.3s ease;
  border: none;
}

.empty-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(14, 165, 233, 0.2);
}

/* 底部操作 - 现代化设计 */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: rgba(240, 249, 255, 0.9);
  backdrop-filter: blur(20px);
  padding: 30rpx 40rpx;
  box-sizing: border-box;
  z-index: 100;
  border-top: 1px solid var(--mistake-border);
}

.action-btn {
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, var(--mistake-primary) 0%, var(--mistake-primary-dark) 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 233, 0.3);
}

.action-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(14, 165, 233, 0.2);
}

.action-btn .icon {
  margin-right: 12rpx;
  font-size: 36rpx;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}
