<view class="container">
  <!-- 头部背景区域 -->
  <view class="header-bg">
    <view class="header-title-area" style="padding-top: {{statusBarHeight}}px; height: {{navHeight}}px;">
      <text class="header-title">我的</text>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="content-wrapper">
    
    <!-- 用户信息卡片 -->
    <view class="user-card" bindtap="{{!userInfo ? 'goLogin' : ''}}">
      <view class="user-card-top">
        <view class="avatar-box">
          <image class="avatar" src="{{userInfo.avatar || '/images/default_avatar.png'}}" mode="aspectFill"></image>
        </view>
        <view class="info-box">
          <block wx:if="{{!userInfo}}">
            <text class="nickname-large">点击登录</text>
            <text class="desc-text">登录同步学习数据</text>
          </block>
          <block wx:else>
            <view class="nickname-row">
              <text class="nickname-large">{{userInfo.nickname || '同学'}}</text>
            </view>
            <text class="account-text">ID: {{userInfo.displayAccount}}</text>
            <view class="join-time-row" wx:if="{{userInfo.joinDate}}">
              <text class="time-text">加入时间: {{userInfo.joinDate}}</text>
            </view>
          </block>
        </view>
        <view class="edit-btn" wx:if="{{userInfo}}" catchtap="navigateTo" data-url="/pages/profile/edit/index">
          <text>编辑资料</text>
        </view>
      </view>
      
      <!-- 学习统计数据 -->
      <view class="user-stats" wx:if="{{userInfo}}">
        <view class="stat-item">
          <text class="stat-num">{{stats.study_days || 0}}</text>
          <text class="stat-label">学习天数</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">{{stats.question_count || 0}}</text>
          <text class="stat-label">练习题目</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">{{stats.accuracy || '0%'}}</text>
          <text class="stat-label">平均正确率</text>
        </view>
      </view>
    </view>

    <!-- 常用功能 (宫格导航) -->
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">常用功能</text>
      </view>
      <view class="grid-menu">
        <view class="grid-item" bindtap="showTip">
          <view class="grid-icon-circle color-yellow-bg">
            <text>⭐</text>
          </view>
          <text class="grid-text">我的收藏</text>
        </view>
        <view class="grid-item" bindtap="showTip">
          <view class="grid-icon-circle color-blue-bg">
            <text>🕒</text>
          </view>
          <text class="grid-text">练习记录</text>
        </view>
        <view class="grid-item" bindtap="navigateTo" data-url="/pages/profile/edit/index">
          <view class="grid-icon-circle color-green-bg">
            <text>📝</text>
          </view>
          <text class="grid-text">个人信息</text>
        </view>
        <view class="grid-item" bindtap="showTip">
          <view class="grid-icon-circle color-purple-bg">
            <text>🛡️</text>
          </view>
          <text class="grid-text">账号安全</text>
        </view>
      </view>
    </view>

    <!-- 更多服务 (列表导航) -->
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">更多服务</text>
      </view>
      <view class="list-menu">
        <view class="list-item" bindtap="showTip">
          <view class="item-left">
            <text class="item-icon">❓</text>
            <text class="item-text">帮助与反馈</text>
          </view>
          <text class="item-arrow">></text>
        </view>
        <view class="list-item" bindtap="showTip">
          <view class="item-left">
            <text class="item-icon">🧹</text>
            <text class="item-text">清除缓存</text>
          </view>
          <text class="item-arrow">></text>
        </view>
        <view class="list-item" bindtap="showTip">
          <view class="item-left">
            <text class="item-icon">ℹ️</text>
            <text class="item-text">关于我们</text>
          </view>
          <text class="item-arrow">></text>
        </view>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-area" wx:if="{{userInfo}}">
      <button class="btn-logout" bindtap="handleLogout">退出登录</button>
      <view class="version-text">v1.0.0</view>
    </view>
    
    <!-- 底部占位 -->
    <view style="height: 40rpx;"></view>
  </view>
</view>
