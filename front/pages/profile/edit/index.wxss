page {
  background-color: var(--color-bg);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", STHeiti, "Microsoft YaHei", sans-serif;
  color: var(--color-text-main);
}

.container {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.content-wrapper {
  width: 100%;
}

/* 卡片样式 */
.section-card {
  background: var(--color-surface);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  padding: 0 32rpx;
  box-shadow: var(--shadow-md);
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #F9F9F9;
  min-height: 48rpx;
}

.form-item:last-child {
  border-bottom: none;
}

.avatar-item {
  padding: 24rpx 0;
}

.label {
  font-size: 30rpx;
  color: var(--color-text-main);
  width: 160rpx;
  font-weight: 500;
}

.input {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text-main);
  text-align: right;
}

.picker-value {
  font-size: 30rpx;
  color: var(--color-text-main);
  text-align: right;
  flex: 1;
}

.picker-value.placeholder {
  color: var(--color-text-light);
}

.static-text {
  font-size: 30rpx;
  color: var(--color-text-sub);
  text-align: right;
  flex: 1;
}

.right-content {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #E2E8F0;
  margin-right: 16rpx;
  border: 2rpx solid #F0F0F0;
}

.arrow {
  color: #CBD5E1;
  font-size: 26rpx;
  margin-left: 12rpx;
}

/* 保存按钮 */
.save-btn {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 60rpx;
  box-shadow: 0 8rpx 20rpx rgba(79, 70, 229, 0.3);
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
}

.save-btn:active {
  opacity: 0.9;
  transform: scale(0.99);
}

.save-btn[loading] {
  background: #7FB2F0;
  color: rgba(255, 255, 255, 0.8);
}
