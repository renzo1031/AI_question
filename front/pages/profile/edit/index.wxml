<view class="container">
  <view class="content-wrapper">
    <!-- 头像 -->
    <view class="section-card">
      <view class="form-item avatar-item" bindtap="chooseAvatar">
        <text class="label">头像</text>
        <view class="right-content">
          <image class="avatar" src="{{formData.avatar || '/images/default_avatar.png'}}" mode="aspectFill"></image>
          <text class="arrow">></text>
        </view>
      </view>
    </view>

    <!-- 基本信息 -->
    <view class="section-card">
      <view class="form-item">
        <text class="label">昵称</text>
        <input class="input" value="{{formData.nickname}}" data-field="nickname" bindinput="handleInput" placeholder="请输入昵称" />
      </view>
      
      <view class="form-item">
        <text class="label">性别</text>
        <picker bindchange="handleGenderChange" value="{{genderIndex}}" range="{{genders}}" range-key="label">
          <view class="picker-value {{formData.gender ? '' : 'placeholder'}}">
            {{genders[genderIndex].label || '请选择性别'}}
          </view>
        </picker>
        <text class="arrow">></text>
      </view>

      <view class="form-item">
        <text class="label">生日</text>
        <picker mode="date" value="{{formData.birthday}}" start="1900-01-01" end="{{today}}" bindchange="handleBirthdayChange">
          <view class="picker-value {{formData.birthday ? '' : 'placeholder'}}">
            {{formData.birthday || '请选择生日'}}
          </view>
        </picker>
        <text class="arrow">></text>
      </view>
    </view>

    <!-- 账号信息 (只读) -->
    <view class="section-card">
      <view class="form-item">
        <text class="label">手机号</text>
        <view class="static-text">{{formData.phone || '未绑定'}}</view>
      </view>
      
      <view class="form-item">
        <text class="label">邮箱</text>
        <view class="static-text">{{formData.email || '未绑定'}}</view>
      </view>

      <view class="form-item" wx:if="{{formData.created_at}}">
        <text class="label">注册时间</text>
        <view class="static-text">{{formData.created_at}}</view>
      </view>
    </view>

    <button class="save-btn" bindtap="handleSave" loading="{{loading}}">保存修改</button>
  </view>
</view>
