page {
  background-color: var(--color-bg);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", STHeiti, "Microsoft YaHei", sans-serif;
  color: var(--color-text-main);
}

.page {
  min-height: 100vh;
  padding-bottom: 150rpx;
  box-sizing: border-box;
}

.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(16px);
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-sizing: border-box;
  z-index: 200;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.nav-left,
.nav-right {
  width: 160rpx;
  display: flex;
  align-items: center;
}

.nav-right {
  justify-content: flex-end;
}

.nav-back {
  font-size: 28rpx;
  color: var(--color-text-main);
  font-weight: 700;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  color: var(--color-text-main);
  font-weight: 800;
}

.top-spacer {
  width: 100%;
}

.hero {
  padding: 24rpx 32rpx 18rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}

.hero-sub {
  margin-top: 0;
  font-size: 24rpx;
  color: var(--color-text-light);
}

.content {
  padding: 0 32rpx 32rpx;
  margin-top: 0rpx;
  box-sizing: border-box;
}

.card {
  background: var(--color-surface);
  border-radius: 28rpx;
  box-shadow: 0 10rpx 30rpx rgba(17, 24, 39, 0.06);
  margin-bottom: 24rpx;
  overflow: hidden;
}

.image-card {
  padding: 0;
  position: relative;
}

.capture {
  width: 100%;
  height: 360rpx;
  display: block;
  background: #F2F4F7;
}

.image-actions {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  display: flex;
  gap: 16rpx;
}

.image-pill {
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(8px);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
}

.image-pill-text {
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
}

.question-card,
.answer-card,
.tab-card {
  padding: 32rpx;
}

.card-head,
.answer-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title,
.answer-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--color-text-main);
  position: relative;
  padding-left: 20rpx;
}

.card-title::before,
.answer-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: var(--color-primary);
  border-radius: 4rpx;
}

.answer-title::before {
  background: var(--color-accent);
}

.head-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.pill {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.pill-easy {
  background: #E6F7EF;
  color: var(--color-accent);
}

.pill-medium {
  background: #FFF7E6;
  color: var(--color-warning);
}

.pill-hard {
  background: #FFF1F0;
  color: var(--color-danger);
}

.pill-text {
  font-size: 22rpx;
  font-weight: 600;
}

.icon-btn {
  padding: 8rpx 16rpx;
  background: #F5F6F7;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
}

.icon-text {
  font-size: 22rpx;
  color: #646A73;
  font-weight: 500;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.meta-pill {
  background: #F2F3F5;
  color: #646A73;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.card-body,
.answer-main {
  font-size: 30rpx;
  line-height: 1.6;
  color: var(--color-text-main);
}

/* Tabs */
.tabs {
  display: flex;
  border-bottom: 1rpx solid #F0F2F5;
  margin-bottom: 24rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  color: #646A73;
  font-weight: 500;
}

.tab-active .tab-text {
  color: var(--color-primary);
  font-weight: 600;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 4rpx;
}

.analysis-block {
  font-size: 28rpx;
  line-height: 1.6;
  color: #4E5969;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F6F7;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #86909C;
}

.detail-value {
  font-size: 28rpx;
  color: #1D2129;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn::after {
  border: none;
}

.btn-ghost {
  background: #F5F6F7;
  color: var(--color-text-main);
}

.btn-primary {
  background: var(--color-primary);
  color: #FFFFFF;
  box-shadow: 0 8rpx 20rpx rgba(79, 70, 229, 0.3);
}

.spacer {
  height: 40rpx;
}

/* Loading */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding-top: 200rpx;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #E2E8F0;
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 40rpx;
}

.loading-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-main);
  margin-bottom: 16rpx;
}

.loading-sub {
  font-size: 26rpx;
  color: var(--color-text-sub);
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4px);
}

.modal-container {
  width: 600rpx;
  background: var(--color-surface);
  border-radius: 24rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-main);
  display: block;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-textarea {
  width: 100%;
  height: 200rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--color-text-main);
  margin-bottom: 32rpx;
}

.placeholder {
  color: var(--color-text-light);
}

.modal-footer {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.modal-cancel {
  background: #F5F6F7;
  color: #646A73;
}

.modal-confirm {
  background: var(--color-primary);
  color: #FFFFFF;
}

.btn-disabled {
  opacity: 0.6;
}
