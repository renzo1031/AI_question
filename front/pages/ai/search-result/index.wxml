<view class="page">
  <block wx:if="{{!loading && result}}">
    <view class="nav" style="padding-top: {{statusBarHeight}}px; height: {{navHeight}}px;">
      <view class="nav-left" bindtap="goBack">
        <text class="nav-back">返回</text>
      </view>
      <text class="nav-title">搜题结果</text>
      <view class="nav-right"></view>
    </view>

    <view class="top-spacer" style="height: {{navHeight}}px;"></view>

    <view class="hero">
      <text class="hero-sub" wx:if="{{metaLine}}">{{metaLine}}</text>
    </view>

    <view class="content">
      <view class="card image-card" wx:if="{{imagePath}}">
        <image class="capture" src="{{imagePath}}" mode="aspectFill" bindtap="previewImage"></image>
        <view class="image-actions">
          <view class="image-pill" bindtap="previewImage">
            <text class="image-pill-text">查看原图</text>
          </view>
        </view>
      </view>

      <view class="card question-card">
        <view class="card-head">
          <text class="card-title">题目</text>
          <view class="head-actions">
            <view class="pill {{difficultyClass}}" wx:if="{{difficultyText}}">
              <text class="pill-text">{{difficultyText}}</text>
            </view>
            <view class="icon-btn" bindtap="copyQuestion">
              <text class="icon-text">复制</text>
            </view>
          </view>
        </view>

        <view class="meta-row" wx:if="{{subjectText || typeText}}">
          <text class="meta-pill" wx:if="{{subjectText}}">{{subjectText}}</text>
          <text class="meta-pill" wx:if="{{typeText}}">{{typeText}}</text>
        </view>

        <view class="card-body">
          <rich-text nodes="{{renderedQuestion}}" user-select="true"></rich-text>
        </view>
      </view>

      <view class="card answer-card" wx:if="{{result.answer}}">
        <view class="answer-head">
          <text class="answer-title">答案</text>
          <view class="icon-btn answer-copy" bindtap="copyAnswer">
            <text class="icon-text">复制</text>
          </view>
        </view>
        <view class="answer-main">
          <rich-text nodes="{{renderedAnswer}}" user-select="true"></rich-text>
        </view>
      </view>

      <view class="card tab-card" wx:if="{{result.answer && result.answer.analysis}}">
        <view class="tabs">
          <view class="tab {{tab === 'analysis' ? 'tab-active' : ''}}" data-tab="analysis" bindtap="switchTab">
            <text class="tab-text">解析</text>
          </view>
          <view class="tab {{tab === 'detail' ? 'tab-active' : ''}}" data-tab="detail" bindtap="switchTab">
            <text class="tab-text">详情</text>
          </view>
        </view>

        <view class="tab-body" wx:if="{{tab === 'analysis'}}">
          <view class="analysis-block">
            <rich-text nodes="{{renderedAnalysis}}" user-select="true"></rich-text>
          </view>
        </view>

        <view class="tab-body" wx:else>
          <view class="detail-row" wx:if="{{metaLine}}">
            <text class="detail-label">信息</text>
            <text class="detail-value">{{metaLine}}</text>
          </view>
          <view class="detail-row" wx:if="{{result.question && result.question.width}}">
            <text class="detail-label">图片尺寸</text>
            <text class="detail-value">{{result.question.width}}×{{result.question.height}}</text>
          </view>
        </view>
      </view>

      <view class="spacer"></view>
    </view>

    <view class="bottom-bar">
      <button class="btn btn-ghost" style="flex: 0.8;" bindtap="openCorrectionModal">纠错</button>
      <button class="btn btn-primary" bindtap="goToCamera">再拍一题</button>
    </view>
  </block>

  <view class="loading-container" wx:else>
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">AI 正在努力解题中...</text>
      <text class="loading-sub">可能需要几秒钟，请稍候</text>
    </view>
  </view>

  <!-- 纠错弹窗 -->
  <view class="modal-mask" wx:if="{{showCorrectionModal}}" bindtap="closeCorrectionModal">
    <view class="modal-container" catchtap="stopProp">
      <text class="modal-title">题目纠错</text>
      <textarea class="modal-textarea" placeholder="请告诉我们哪里出错了..." placeholder-class="placeholder" value="{{correctionReason}}" bindinput="onReasonInput" maxlength="200"></textarea>
      <view class="modal-footer">
        <view class="modal-btn modal-cancel" bindtap="closeCorrectionModal">取消</view>
        <view class="modal-btn modal-confirm {{submittingCorrection ? 'btn-disabled' : ''}}" bindtap="submitCorrection">{{submittingCorrection ? '提交中...' : '提交反馈'}}</view>
      </view>
    </view>
  </view>
</view>
