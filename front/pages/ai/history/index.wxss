.container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding: 20rpx;
}

.history-item {
  background-color: var(--color-surface);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.provider-tag {
  background-color: #EEF2FF;
  color: var(--color-primary);
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.time {
  color: var(--color-text-light);
  font-size: 24rpx;
}

.item-content {
  margin-bottom: 20rpx;
}

.question {
  font-size: 30rpx;
  color: var(--color-text-main);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  font-weight: 500;
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.count {
  font-size: 24rpx;
  color: var(--color-text-light);
}

.arrow {
  color: #ccc;
  font-size: 24rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.empty text {
  color: var(--color-text-sub);
  font-size: 28rpx;
}

.loading, .no-more {
  text-align: center;
  padding: 20rpx;
  color: var(--color-text-light);
  font-size: 24rpx;
}
