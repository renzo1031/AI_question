page {
  background-color: var(--color-bg);
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: var(--color-bg);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", STHeiti, "Microsoft YaHei", sans-serif;
  box-sizing: border-box;
}

.header {
  height: 96rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
  z-index: 100;
  position: relative;
}

.provider-info {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: var(--color-text-main);
  background-color: #F8FAFC;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

.provider-info .name {
  color: var(--color-primary);
  font-weight: 600;
  margin: 0 8rpx;
}

.provider-info .arrow {
  font-size: 20rpx;
  color: var(--color-text-light);
  margin-left: 4rpx;
}

.history-btn {
  font-size: 26rpx;
  color: var(--color-text-sub);
  padding: 10rpx 24rpx;
  background-color: var(--color-surface);
  border: 1rpx solid #E2E8F0;
  border-radius: 30rpx;
  font-weight: 500;
}

.chat-list {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}

.message-item {
  display: flex;
  margin-bottom: 48rpx;
  opacity: 0;
  animation: fadeIn 0.3s ease forwards;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.message-item.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  overflow: hidden;
  margin: 0 24rpx;
  flex-shrink: 0;
  box-shadow: var(--shadow-sm);
  background-color: var(--color-surface);
}

.avatar image {
  width: 100%;
  height: 100%;
}

.content {
  max-width: 72%;
  display: flex;
  flex-direction: column;
}

.message-item.user .content {
  align-items: flex-end;
}

.bubble {
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  line-height: 1.6;
  position: relative;
  word-break: break-all;
  transition: all 0.2s;
}

/* User Bubble */
.message-item.user .bubble {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: #fff;
  border-top-right-radius: 6rpx;
  box-shadow: 0 4rpx 12rpx rgba(43, 119, 248, 0.25);
}

/* AI Bubble */
.message-item.ai .bubble {
  background-color: var(--color-surface);
  color: var(--color-text-main);
  border-top-left-radius: 6rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.actions {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
  margin-left: 4rpx;
}

.action-btn {
  background-color: var(--color-surface);
  color: var(--color-primary);
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  margin-right: 16rpx;
  margin-top: 8rpx;
  border: 1rpx solid #EEF2FF;
  box-shadow: 0 2rpx 6rpx rgba(15, 23, 42, 0.06);
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background-color: var(--color-surface);
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.03);
  z-index: 200;
}

.model-bar {
  padding: 12rpx 32rpx 0;
  display: flex;
  justify-content: flex-start;
}

.model-tag {
  display: flex;
  align-items: center;
  background-color: #EEF2FF;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  color: var(--color-primary);
}

.model-tag .label {
  color: var(--color-text-sub);
  margin-right: 8rpx;
}

.model-tag .name {
  font-weight: 600;
  margin-right: 8rpx;
}

.model-tag .arrow {
  color: var(--color-text-light);
  font-size: 20rpx;
}

.input-area {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
}

.tool-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  background-color: #E5E7EB;
  border-radius: 50%;
  transition: transform 0.2s;
}

.tool-btn:active {
  transform: scale(0.9);
}

.plus {
  font-size: 40rpx;
  color: var(--color-text-sub);
  font-weight: 300;
  margin-top: -4rpx;
}

.input-box {
  flex: 1;
  background-color: #E5E7EB;
  height: 80rpx;
  border-radius: 40rpx;
  padding: 0 36rpx;
  font-size: 28rpx;
  color: var(--color-text-main);
}

.send-btn {
  width: 110rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background-color: #E5E7EB;
  color: var(--color-text-light);
  border-radius: 36rpx;
  font-size: 28rpx;
  margin-left: 20rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.send-btn.active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(43, 119, 248, 0.25);
}

.tools-panel {
  display: flex;
  padding: 40rpx 32rpx;
  border-top: 1rpx solid #E2E8F0;
  height: 240rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(20rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 64rpx;
}

.tool-item .icon {
  width: 110rpx;
  height: 110rpx;
  background-color: #F8FAFC;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-bottom: 16rpx;
  transition: transform 0.2s;
}

.tool-item:active .icon {
  transform: scale(0.95);
  background-color: #EEF2FF;
}

.tool-item text {
  font-size: 24rpx;
  color: var(--color-text-sub);
  font-weight: 500;
}

/* 独立的思考中状态动画 */
.thinking-indicator {
  padding: 12rpx 20rpx;
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
  background-color: transparent;
}

.thinking-indicator .dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #ccc;
  border-radius: 50%;
  margin: 0 6rpx;
  animation: thinking 1.4s infinite ease-in-out both;
}

.thinking-indicator .dot:nth-child(1) { animation-delay: -0.32s; }
.thinking-indicator .dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes thinking {
  0%, 80%, 100% { transform: scale(0); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}
