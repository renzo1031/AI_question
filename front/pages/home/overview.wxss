/* 学习概览页面样式 */
.page-container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, var(--td-brand-color), var(--td-brand-color-light));
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  color: white;
  box-shadow: var(--td-shadow-2);
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-details {
  flex: 1;
}

.username {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.study-time {
  font-size: 26rpx;
  opacity: 0.8;
}

.user-stats {
  display: flex;
  justify-content: space-between;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 数据卡片 */
.data-card {
  margin-bottom: 24rpx;
}

.chart-container {
  padding: 16rpx 0;
}

.chart-title {
  font-size: 30rpx;
  color: var(--td-text-color-primary);
  margin-bottom: 24rpx;
  text-align: center;
}

.week-chart {
  padding: 0 16rpx;
}

.chart-bar-container {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 150rpx;
  margin-bottom: 16rpx;
}

.chart-bar {
  width: 40rpx;
  border-radius: 6rpx 6rpx 0 0;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-label {
  position: absolute;
  top: -30rpx;
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.chart-legend {
  display: flex;
  justify-content: center;
}

.legend-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
}

.legend-color {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
}

/* 学科进度卡片 */
.progress-card {
  margin-bottom: 24rpx;
}

.subject-progress {
  margin-bottom: 24rpx;
}

.subject-progress:last-child {
  margin-bottom: 0;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.subject-name {
  font-size: 28rpx;
  color: var(--td-text-color-primary);
}

.progress-percent {
  font-size: 28rpx;
  color: var(--td-brand-color);
  font-weight: 500;
}

/* 任务卡片 */
.task-card {
  margin-bottom: 24rpx;
}

.task-list {
  margin-bottom: 24rpx;
}

.task-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid var(--td-border-color);
}

.task-item:last-child {
  border-bottom: none;
}

.task-info {
  flex: 1;
  padding-right: 24rpx;
}

.task-title {
  font-size: 30rpx;
  color: var(--td-text-color-primary);
  margin-bottom: 8rpx;
}

.task-desc {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
}

.task-status {
  flex-shrink: 0;
}

.task-more {
  display: flex;
  justify-content: center;
}

/* 快捷入口卡片 */
.shortcut-card {
  margin-bottom: 24rpx;
}

/* 学习建议卡片 */
.suggestion-card {
  margin-bottom: 24rpx;
}

.suggestion-list {
  padding: 8rpx 0;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background-color: rgba(237, 123, 47, 0.05);
  border-radius: 12rpx;
}

.suggestion-item:last-child {
  margin-bottom: 0;
}

.suggestion-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--td-text-color-secondary);
  margin-left: 16rpx;
  line-height: 1.5;
}

/* 加载状态 */
.t-loading {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}