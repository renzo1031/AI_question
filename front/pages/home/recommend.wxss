/* pages/home/recommend.wxss */
.recommend-container {
  padding: 0 24rpx 24rpx;
  background-color: var(--td-bg-color-page);
  min-height: 100vh;
}

/* 标签页样式 */
.tabs-container {
  margin-bottom: 24rpx;
}

.tab-content {
  margin-top: 24rpx;
}

/* 推荐内容通用样式 */
.recommend-item {
  margin-bottom: 24rpx;
  transition: all 0.3s ease;
}

.recommend-item:last-child {
  margin-bottom: 0;
}

.recommend-item:active {
  transform: scale(0.98);
}

/* 练习推荐样式 */
.practice-item {
  border-radius: var(--td-radius-large);
}

.practice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.practice-title {
  font-size: var(--td-font-size-title-large);
  font-weight: 600;
  color: var(--td-text-color-primary);
  flex: 1;
  margin-right: 16rpx;
}

.practice-difficulty {
  font-size: var(--td-font-size-body-small);
  padding: 4rpx 12rpx;
  border-radius: var(--td-radius-medium);
}

.practice-description {
  font-size: var(--td-font-size-body-medium);
  color: var(--td-text-color-secondary);
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.practice-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.practice-tag {
  font-size: var(--td-font-size-body-small);
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.practice-stats {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.practice-stat {
  display: flex;
  align-items: center;
  font-size: var(--td-font-size-body-small);
  color: var(--td-text-color-placeholder);
}

.practice-stat .t-icon {
  margin-right: 6rpx;
  font-size: 28rpx;
}

/* 知识点推荐样式 */
.knowledge-item {
  border-radius: var(--td-radius-large);
}

.knowledge-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.knowledge-title {
  font-size: var(--td-font-size-title-large);
  font-weight: 600;
  color: var(--td-text-color-primary);
  flex: 1;
  margin-right: 16rpx;
}

.knowledge-subject {
  font-size: var(--td-font-size-body-small);
  padding: 4rpx 12rpx;
  border-radius: var(--td-radius-medium);
  background-color: var(--td-brand-color-light);
  color: var(--td-brand-color);
}

.knowledge-description {
  font-size: var(--td-font-size-body-medium);
  color: var(--td-text-color-secondary);
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.knowledge-progress {
  margin-bottom: 16rpx;
}

.knowledge-stats {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.knowledge-stat {
  display: flex;
  align-items: center;
  font-size: var(--td-font-size-body-small);
  color: var(--td-text-color-placeholder);
}

.knowledge-stat .t-icon {
  margin-right: 6rpx;
  font-size: 28rpx;
}

/* 课程推荐样式 */
.course-item {
  border-radius: var(--td-radius-large);
  overflow: hidden;
}

.course-cover {
  width: 100%;
  height: 300rpx;
  border-radius: var(--td-radius-large) var(--td-radius-large) 0 0;
  object-fit: cover;
}

.course-content {
  padding: 24rpx;
}

.course-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.course-title {
  font-size: var(--td-font-size-title-large);
  font-weight: 600;
  color: var(--td-text-color-primary);
  flex: 1;
  margin-right: 16rpx;
}

.course-hot {
  font-size: var(--td-font-size-body-small);
  color: var(--td-error-color);
}

.course-description {
  font-size: var(--td-font-size-body-medium);
  color: var(--td-text-color-secondary);
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.course-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.course-teacher {
  font-size: var(--td-font-size-body-medium);
  color: var(--td-text-color-secondary);
}

.course-duration {
  font-size: var(--td-font-size-body-small);
  color: var(--td-text-color-placeholder);
}

.course-stats {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.course-students {
  font-size: var(--td-font-size-body-small);
  color: var(--td-text-color-placeholder);
}

.course-rating {
  display: flex;
  align-items: center;
  font-size: var(--td-font-size-body-small);
  color: var(--td-warning-color);
}

.course-rating .t-icon {
  margin-right: 6rpx;
  font-size: 28rpx;
}

/* 空状态样式 */
.empty-container {
  padding: 120rpx 0;
  text-align: center;
}

.empty-text {
  margin-top: 24rpx;
  font-size: var(--td-font-size-body-medium);
  color: var(--td-text-color-secondary);
}

/* 加载状态样式 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 0;
}