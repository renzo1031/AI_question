<!--pages/home/progress.wxml-->
<view class="progress-container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <t-loading theme="circular" size="40rpx" text="加载中..." />
  </view>
  
  <!-- 内容区域 -->
  <view wx:else>
    <!-- 总体进度概览 -->
    <view class="overall-progress">
      <t-card title="总体学习进度" description="各科目学习完成情况">
        <view class="overall-stats">
          <view class="stat-item">
            <view class="stat-value">{{overallProgress.completed}}</view>
            <view class="stat-label">已完成章节</view>
          </view>
          <view class="stat-item">
            <view class="stat-value">{{overallProgress.total}}</view>
            <view class="stat-label">总章节数</view>
          </view>
          <view class="stat-item">
            <view class="stat-value">{{overallProgress.percentage}}%</view>
            <view class="stat-label">完成率</view>
          </view>
        </view>
        <view class="overall-progress-bar">
          <t-progress 
            percentage="{{overallProgress.percentage}}" 
            strokeWidth="12rpx"
            color="#0052d9"
            trackColor="#f3f3f3"
          />
        </view>
      </t-card>
    </view>
    
    <!-- 分类进度 -->
    <view class="progress-tabs">
      <t-tabs value="{{activeTab}}" bind:change="onTabChange">
        <t-tab-panel value="subject" label="科目进度" />
        <t-tab-panel value="chapter" label="章节进度" />
        <t-tab-panel value="knowledge" label="知识点进度" />
      </t-tabs>
      
      <!-- 科目进度 -->
      <view class="tab-content" wx:if="{{activeTab === 'subject'}}">
        <view class="progress-list">
          <t-card wx:for="{{subjectProgress}}" wx:key="id" class="progress-item">
            <view class="progress-header">
              <view class="progress-title">
                <t-icon name="{{item.icon}}" size="40rpx" color="{{item.color}}" />
                <text class="title-text">{{item.name}}</text>
              </view>
              <view class="progress-percentage">{{item.percentage}}%</view>
            </view>
            <view class="progress-bar">
              <t-progress 
                percentage="{{item.percentage}}" 
                strokeWidth="8rpx"
                color="{{item.color}}"
                trackColor="#f3f3f3"
              />
            </view>
            <view class="progress-details">
              <view class="detail-item">
                <t-icon name="time" size="28rpx" color="#999" />
                <text>学习时长: {{item.studyTime}}</text>
              </view>
              <view class="detail-item">
                <t-icon name="check-circle" size="28rpx" color="#999" />
                <text>已完成: {{item.completed}}/{{item.total}}</text>
              </view>
            </view>
            <view class="progress-actions">
              <t-button size="small" variant="outline" bindtap="goToSubjectDetail" data-id="{{item.id}}">
                查看详情
              </t-button>
            </view>
          </t-card>
        </view>
      </view>
      
      <!-- 章节进度 -->
      <view class="tab-content" wx:if="{{activeTab === 'chapter'}}">
        <view class="chapter-list">
          <t-cell-group>
            <t-cell 
              wx:for="{{chapterProgress}}" 
              wx:key="id"
              title="{{item.subject}}"
              description="{{item.description}}"
              arrow
              bind:click="goToChapterDetail"
              data-id="{{item.id}}"
            >
              <view slot="note" class="chapter-progress">
                <t-progress 
                  percentage="{{item.percentage}}" 
                  strokeWidth="6rpx"
                  color="#0052d9"
                  trackColor="#f3f3f3"
                />
                <text class="progress-text">{{item.percentage}}%</text>
              </view>
            </t-cell>
          </t-cell-group>
        </view>
      </view>
      
      <!-- 知识点进度 -->
      <view class="tab-content" wx:if="{{activeTab === 'knowledge'}}">
        <view class="knowledge-list">
          <t-card wx:for="{{knowledgeProgress}}" wx:key="id" class="knowledge-item">
            <view class="knowledge-header">
              <view class="knowledge-title">{{item.name}}</view>
              <view class="knowledge-mastery">
                <t-tag 
                  theme="{{item.mastery >= 80 ? 'success' : item.mastery >= 60 ? 'warning' : 'danger'}}" 
                  variant="light"
                  size="small"
                >
                  掌握度: {{item.mastery}}%
                </t-tag>
              </view>
            </view>
            <view class="knowledge-progress">
              <t-progress 
                percentage="{{item.mastery}}" 
                strokeWidth="8rpx"
                color="{{item.mastery >= 80 ? '#00a870' : item.mastery >= 60 ? '#ed7b2f' : '#d54941'}}"
                trackColor="#f3f3f3"
              />
            </view>
            <view class="knowledge-details">
              <view class="detail-item">
                <text>所属科目: {{item.subject}}</text>
              </view>
              <view class="detail-item">
                <text>相关题目: {{item.questionCount}}道</text>
              </view>
              <view class="detail-item">
                <text>正确率: {{item.accuracy}}%</text>
              </view>
            </view>
            <view class="knowledge-actions">
              <t-button size="small" variant="outline" bindtap="practiceKnowledge" data-id="{{item.id}}">
                练习
              </t-button>
              <t-button size="small" variant="text" bindtap="reviewKnowledge" data-id="{{item.id}}">
                复习
              </t-button>
            </view>
          </t-card>
        </view>
      </view>
    </view>
    
    <!-- 空状态 -->
    <view wx:if="{{!loading && empty}}" class="empty-container">
      <t-empty description="暂无学习进度数据" />
    </view>
  </view>
</view>