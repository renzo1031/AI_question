page {
  background-color: var(--color-bg);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", STHeiti, "Microsoft YaHei", sans-serif;
  
  /* 忘记密码页面专用配色 - 天空蓝主题 */
  --forgot-primary: #0EA5E9;        /* 天空蓝主色 */
  --forgot-primary-light: #38BDF8;  /* 浅天空蓝 */
  --forgot-primary-dark: #0284C7;   /* 深天空蓝 */
  --forgot-text-primary: #1E293B;   /* 更深的蓝灰色文字 */
  --forgot-text-secondary: #475569; /* 次要文字调整为中等深度 */
  --forgot-text-light: #64748B;     /* 浅色文字保持 */
  --forgot-input-bg: #F0F9FF;       /* 极淡蓝输入框 */
  --forgot-border: #BAE6FD;         /* 淡蓝边框 */
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background-image: linear-gradient(180deg, #F0F9FF 0%, #E0F2FE 100%);
}

.content {
  padding: 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.header {
  margin-bottom: 60rpx;
  text-align: center;
}

.logo-box {
  width: 120rpx;
  height: 120rpx;
  background: #ffffff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
  box-shadow: var(--shadow-md);
}

.logo {
  font-size: 64rpx;
}

.greeting .title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--forgot-text-primary);
  margin-bottom: 16rpx;
}

.greeting .subtitle {
  font-size: 30rpx;
  color: var(--forgot-text-secondary);
}

.card {
  background: var(--color-surface);
  border-radius: 40rpx;
  padding: 50rpx 40rpx;
  box-shadow: var(--shadow-lg);
}

.form-group {
  margin-bottom: 50rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: var(--forgot-input-bg);
  border-radius: 24rpx;
  padding: 0 30rpx;
  height: 100rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid var(--forgot-border);
  transition: all 0.3s;
}

.input-wrapper:focus-within {
  background: #ffffff;
  border-color: var(--forgot-primary);
  box-shadow: 0 0 0 4rpx rgba(99, 102, 241, 0.15);
}

.icon {
  font-size: 36rpx;
  margin-right: 24rpx;
  color: var(--forgot-primary);
}

.input-field {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
  color: var(--forgot-text-primary);
}

.password-input {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
  color: var(--forgot-text-primary);
  padding-right: 20rpx;
}

.placeholder {
  color: var(--forgot-text-light);
}

.code-wrapper {
  padding-right: 20rpx;
}

.code-btn {
  font-size: 26rpx;
  color: var(--forgot-primary);
  background: rgba(99, 102, 241, 0.1);
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  font-weight: 500;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.submit-btn {
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx;
  background: var(--forgot-primary);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  box-shadow: 0 10rpx 20rpx rgba(99, 102, 241, 0.3);
  padding: 0;
  margin-bottom: 40rpx;
  margin-top: 0;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 10rpx rgba(99, 102, 241, 0.25);
}

.footer-links {
  margin-top: 40rpx;
  text-align: center;
  font-size: 28rpx;
}

.footer-links .text {
  color: var(--forgot-text-secondary);
}

.footer-links .link {
  color: var(--forgot-primary);
  font-weight: 600;
  margin-left: 10rpx;
}

.password-toggle {
  font-size: 28rpx;
  padding: 8rpx;
  opacity: 0.6;
  transition: opacity 0.2s;
  color: var(--forgot-text-light);
  flex-shrink: 0;
}

.password-toggle:active {
  opacity: 1;
}

.toggle-icon {
  font-size: 28rpx;
}
