<view class="container">
  <view class="content">
    <view class="header">
      <view class="logo-box">
        <text class="logo">🔐</text>
      </view>
      <view class="greeting">
        <text class="title">重置密码</text>
        <text class="subtitle">请输入您的账号信息以重置密码</text>
      </view>
    </view>

    <view class="card">
      <view class="form-group">
        <!-- 账号输入 -->
        <view class="input-wrapper">
          <view class="icon">👤</view>
          <input class="input-field" type="text" placeholder="手机号 / 邮箱" placeholder-class="placeholder" value="{{account}}" bindinput="onAccountInput" />
        </view>
        
        <!-- 验证码 -->
        <view class="input-wrapper code-wrapper">
          <view class="icon">🛡️</view>
          <input class="input-field" type="number" placeholder="请输入验证码" placeholder-class="placeholder" value="{{code}}" bindinput="onCodeInput" />
          <view class="code-btn {{counting ? 'disabled' : ''}}" bindtap="sendCode">{{counting ? count + 's后重发' : '获取验证码'}}</view>
        </view>

        <!-- 新密码 -->
        <view class="input-wrapper">
          <view class="icon">🔑</view>
          <input class="input-field password-input" type="{{showPassword ? 'text' : 'password'}}" placeholder="设置新密码" placeholder-class="placeholder" value="{{password}}" bindinput="onPasswordInput" />
          <view class="password-toggle" bindtap="togglePasswordVisibility">
            <text class="toggle-icon">{{showPassword ? '👁️' : '🙈'}}</text>
          </view>
        </view>

        <!-- 确认密码 -->
        <view class="input-wrapper">
          <view class="icon">🔐</view>
          <input class="input-field password-input" type="{{showConfirmPassword ? 'text' : 'password'}}" placeholder="确认新密码" placeholder-class="placeholder" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
          <view class="password-toggle" bindtap="toggleConfirmPasswordVisibility">
            <text class="toggle-icon">{{showConfirmPassword ? '👁️' : '🙈'}}</text>
          </view>
        </view>
      </view>

      <button class="submit-btn" bindtap="handleReset" loading="{{loading}}">确认重置</button>

      <view class="footer-links">
        <text class="text">想起来了？</text>
        <text class="link" bindtap="goToLogin">返回登录</text>
      </view>
    </view>
  </view>
</view>
