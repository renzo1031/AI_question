.page {
  min-height: 100vh;
  background: #0b1220;
}

.nav {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  z-index: 10;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(11, 18, 32, 0.95) 0%, rgba(11, 18, 32, 0) 100%);
}

.nav-left,
.nav-right {
  width: 140rpx;
  display: flex;
  align-items: center;
}

.nav-right {
  justify-content: flex-end;
}

.nav-back {
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.nav-action {
  color: rgba(255, 255, 255, 0.92);
  font-size: 28rpx;
}

.top-spacer {
  width: 100%;
}

.stage {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.18);
}

.stage-inner {
  position: relative;
  border-radius: 22rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.stage-image {
  position: absolute;
  left: 0;
  top: 0;
}

.crop-box {
  position: absolute;
  border: 2rpx solid rgba(79, 70, 229, 0.98);
  box-sizing: border-box;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.02);
}

.shade {
  position: absolute;
  left: 0;
  top: 0;
  background: rgba(0, 0, 0, 0.52);
  pointer-events: none;
}

.shade-top {
  width: 100%;
  top: 0;
  left: 0;
}

.shade-bottom {
  width: 100%;
  left: 0;
}

.shade-left {
  left: 0;
}

.shade-right {
  top: 0;
}

.handle {
  position: absolute;
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.95);
  box-sizing: border-box;
  z-index: 20;
}

.handle-nw {
  left: -28rpx;
  top: -28rpx;
}

.handle-ne {
  right: -28rpx;
  top: -28rpx;
}

.handle-sw {
  left: -28rpx;
  bottom: -28rpx;
}

.handle-se {
  right: -28rpx;
  bottom: -28rpx;
}

.handle::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 14rpx;
  height: 14rpx;
  background: rgba(79, 70, 229, 0.95);
  border-radius: 999rpx;
  transform: translate(-50%, -50%);
}

.handle-edge {
  position: absolute;
  background: transparent;
  z-index: 10;
}

.handle-n {
  top: -20rpx;
  left: 20rpx;
  right: 20rpx;
  height: 40rpx;
}

.handle-s {
  bottom: -20rpx;
  left: 20rpx;
  right: 20rpx;
  height: 40rpx;
}

.handle-w {
  left: -20rpx;
  top: 20rpx;
  bottom: 20rpx;
  width: 40rpx;
}

.handle-e {
  right: -20rpx;
  top: 20rpx;
  bottom: 20rpx;
  width: 40rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  background: rgba(11, 18, 32, 0.95);
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.tip {
  width: 100%;
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  line-height: 36rpx;
}

.actions {
  width: 100%;
  display: flex;
  gap: 18rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 88rpx;
  padding: 0;
}

.btn-primary {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  color: #fff;
  border: none;
}

.btn-ghost {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.hidden-canvas {
  position: fixed;
  left: -9999px;
}
