/* 全屏容器 */
.camera-container {
  width: 100vw;
  height: 100vh;
  background: #000;
}

.camera-view {
  width: 100%;
  height: 100%;
}

.camera-overlay {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  position: relative;
}

/* 顶部操作栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 40rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 100%);
}

.icon-btn {
  padding: 20rpx;
}

.icon-back {
  color: #fff;
  font-size: 40rpx;
  font-weight: bold;
}

.flash-btn {
  background: rgba(255, 255, 255, 0.2);
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  backdrop-filter: blur(4px);
}

.icon-flash {
  color: #fff;
  font-size: 24rpx;
}

/* 扫描区域 */
.scan-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
}

.scan-box {
  width: 500rpx;
  height: 500rpx;
  position: relative;
  /* background: rgba(255, 255, 255, 0.1); */
}

/* 扫描框四角 */
.corner {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  border: 6rpx solid var(--color-primary);
  border-radius: 4rpx;
}

.top-left {
  top: 0;
  left: 0;
  border-right: none;
  border-bottom: none;
}

.top-right {
  top: 0;
  right: 0;
  border-left: none;
  border-bottom: none;
}

.bottom-left {
  bottom: 0;
  left: 0;
  border-right: none;
  border-top: none;
}

.bottom-right {
  bottom: 0;
  right: 0;
  border-left: none;
  border-top: none;
}

/* 扫描线动画 */
.scan-line {
  position: absolute;
  width: 100%;
  height: 4rpx;
  background: var(--color-primary);
  box-shadow: 0 0 8rpx rgba(79, 70, 229, 0.8);
  top: 0;
  animation: scan 2.5s infinite linear;
}

@keyframes scan {
  0% { top: 0; opacity: 0.6; }
  50% { top: 100%; opacity: 1; }
  100% { top: 0; opacity: 0.6; }
}

.scan-tip {
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
  margin-top: 40rpx;
  background: rgba(0, 0, 0, 0.4);
  padding: 8rpx 20rpx;
  border-radius: 10rpx;
}

/* 底部操作栏 */
.bottom-bar {
  height: 240rpx;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(10px);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 12rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.history-panel {
  width: 100%;
  margin-bottom: 18rpx;
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.history-title {
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  font-weight: 700;
}

.history-clear {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
}

.history-list {
  width: 100%;
  white-space: nowrap;
}

.history-item {
  display: inline-flex;
  align-items: center;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.10);
  border-radius: 20rpx;
  padding: 12rpx 14rpx;
  margin-right: 14rpx;
  box-sizing: border-box;
}

.history-thumb {
  width: 72rpx;
  height: 72rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.16);
  margin-right: 12rpx;
}

.history-info {
  display: flex;
  flex-direction: column;
  justify-content: center;
  width: 260rpx;
}

.history-q {
  color: rgba(255, 255, 255, 0.92);
  font-size: 24rpx;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-meta {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.controls-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.album-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
  font-size: 24rpx;
  width: 120rpx;
}

.album-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.shutter-btn-outer {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.shutter-btn-inner {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: #fff;
  transition: transform 0.1s;
}

.shutter-btn-outer:active .shutter-btn-inner {
  transform: scale(0.9);
  background: var(--color-primary);
}

.spacer {
  width: 120rpx;
}
