# 应用配置
APP_NAME=AI智能学习系统
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production

# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_question

# Redis配置
REDIS_URL=redis://localhost:6379/0

# JWT配置
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# SM4加密密钥（16字节）
SM4_SECRET_KEY=1234567890abcdef

# Session配置
SESSION_SECRET_KEY=your-session-secret-key
SESSION_EXPIRE_HOURS=24

# 邮件配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@example.com

# 短信配置（阿里云）
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_SMS_SIGN_NAME=your-sign-name
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789

# 阿里云OCR配置
ALIYUN_OCR_ENDPOINT=ocr-api.cn-hangzhou.aliyuncs.com
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret

# =============================================================================
# AI服务配置
# =============================================================================
# 默认AI提供商：tongyi（通义千问）| deepseek | kimi | openai | custom
DEFAULT_AI_PROVIDER=tongyi

# -----------------------------------------------------------------------------
# 通义千问配置（阿里云DashScope）
# 获取API Key: https://dashscope.console.aliyun.com/apiKey
# -----------------------------------------------------------------------------
TONGYI_API_KEY=your-tongyi-api-key
TONGYI_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# 模型选择：qwen-turbo | qwen-plus | qwen-max | qwen-max-longcontext
TONGYI_MODEL=qwen-turbo

# -----------------------------------------------------------------------------
# DeepSeek配置
# 获取API Key: https://platform.deepseek.com/api_keys
# 官方文档: https://api-docs.deepseek.com/zh-cn/
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 模型选择：deepseek-chat（非思考模式）| deepseek-reasoner（思考模式）
DEEPSEEK_MODEL=deepseek-chat

# -----------------------------------------------------------------------------
# Kimi (Moonshot AI) 配置
# 获取API Key: https://platform.moonshot.cn/console/api-keys
# 官方文档: https://platform.moonshot.cn/docs
# -----------------------------------------------------------------------------
KIMI_API_KEY=your-kimi-api-key
KIMI_BASE_URL=https://api.moonshot.cn/v1
# 模型选择：moonshot-v1-8k | moonshot-v1-32k | moonshot-v1-128k
KIMI_MODEL=moonshot-v1-8k

# -----------------------------------------------------------------------------
# OpenAI配置（支持OpenAI官方及兼容服务）
# 获取API Key: https://platform.openai.com/api-keys
# 官方文档: https://platform.openai.com/docs
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
# 模型选择：gpt-3.5-turbo | gpt-4 | gpt-4-turbo | gpt-4o | gpt-4o-mini
OPENAI_MODEL=gpt-3.5-turbo

# -----------------------------------------------------------------------------
# 自定义OpenAI兼容提供商配置
# 用于本地模型或其他兼容OpenAI API格式的服务
# 支持的服务：vLLM、Ollama、LocalAI、Text Generation WebUI等
# -----------------------------------------------------------------------------
# 示例1：使用vLLM部署的本地模型
# CUSTOM_AI_API_KEY=any-value
# CUSTOM_AI_BASE_URL=http://localhost:8000/v1
# CUSTOM_AI_MODEL=Qwen2-7B-Instruct

# 示例2：使用Ollama部署的本地模型
# CUSTOM_AI_API_KEY=ollama
# CUSTOM_AI_BASE_URL=http://localhost:11434/v1
# CUSTOM_AI_MODEL=llama2

# 示例3：使用其他云服务商的OpenAI兼容API
# CUSTOM_AI_API_KEY=your-api-key
# CUSTOM_AI_BASE_URL=https://api.example.com/v1
# CUSTOM_AI_MODEL=your-model-name

# 自定义提供商配置（如使用，请取消注释）
# CUSTOM_AI_API_KEY=
# CUSTOM_AI_BASE_URL=
# CUSTOM_AI_MODEL=
# CUSTOM_AI_TIMEOUT=60.0
# CUSTOM_AI_TEMPERATURE=0.3
# CUSTOM_AI_MAX_TOKENS=2000

# =============================================================================
# MinIO 对象存储配置（首页轮播图图片存储）
# =============================================================================
# MinIO 服务地址（不含协议头），格式：host:port
MINIO_ENDPOINT=localhost:9000
# 访问密钥（对应 MinIO Access Key）
MINIO_ACCESS_KEY=minioadmin
# 密钥（对应 MinIO Secret Key）
MINIO_SECRET_KEY=minioadmin
# 存储桶名称（不存在时会自动创建）
MINIO_BUCKET=banners
# 是否启用 HTTPS，生产环境建议设为 true
MINIO_SECURE=false
# 图片公开访问地址前缀（用于拼接最终 URL）
# 开发环境示例：http://localhost:9000
# 生产环境示例（反向代理域名）：https://cdn.example.com
MINIO_PUBLIC_URL=http://localhost:9000

